-- =============================================
-- =============================================
-- CREATE DATABASE
-- =============================================

DROP DATABASE IF EXISTS RGI_Truckingg;

CREATE DATABASE IF NOT EXISTS RGI_Truckingg;
USE RGI_Truckingg;


-- =============================================
-- CORE ENTITIES (from Question 1.1 table)
-- =============================================

-- Truck table
CREATE TABLE Truck (
    Truck_ID VARCHAR(20) PRIMARY KEY,
    Truck_Desc VARCHAR(100) NOT NULL
);

-- Route table
CREATE TABLE Route (
    Route_ID VARCHAR(10) PRIMARY KEY
);

-- Emergency table (for First Responder to attend)
CREATE TABLE Emergency (
    Emergency_ID INT AUTO_INCREMENT PRIMARY KEY,
    Route_ID VARCHAR(10) NOT NULL,
    Incident_Time DATETIME,
    Description TEXT,
    FOREIGN KEY (Route_ID) REFERENCES Route(Route_ID)
);


-- =============================================
-- Employee SUPERCLASS
-- =============================================

CREATE TABLE Employee (
    Employee_ID VARCHAR(10) PRIMARY KEY,
    First_Name VARCHAR(50) NOT NULL,
    Last_Name VARCHAR(50) NOT NULL,
    Employee_Type VARCHAR(20) NOT NULL  -- Driver, Dispatcher, FirstResponder, Mechanic, Clerk
);


-- =============================================
-- Employee SUBCLASSES (Disjoint Specialization)
-- =============================================

-- Driver
CREATE TABLE Driver (
    Employee_ID VARCHAR(10) PRIMARY KEY,
    Licence_Type VARCHAR(20) NOT NULL,
    Driver_Desc VARCHAR(50),
    Truck_ID VARCHAR(20),
    Route_ID VARCHAR(10),
    FOREIGN KEY (Employee_ID) REFERENCES Employee(Employee_ID) ON DELETE CASCADE,
    FOREIGN KEY (Truck_ID) REFERENCES Truck(Truck_ID),
    FOREIGN KEY (Route_ID) REFERENCES Route(Route_ID)
);

-- Dispatcher
CREATE TABLE Dispatcher (
    Employee_ID VARCHAR(10) PRIMARY KEY,
    Shift VARCHAR(20),
    FOREIGN KEY (Employee_ID) REFERENCES Employee(Employee_ID) ON DELETE CASCADE
);

-- First Responder
CREATE TABLE First_Responder (
    Employee_ID VARCHAR(10) PRIMARY KEY,
    Certification VARCHAR(50),
    FOREIGN KEY (Employee_ID) REFERENCES Employee(Employee_ID) ON DELETE CASCADE
);

-- Mechanic
CREATE TABLE Mechanic (
    Employee_ID VARCHAR(10) PRIMARY KEY,
    Specialization VARCHAR(50),
    FOREIGN KEY (Employee_ID) REFERENCES Employee(Employee_ID) ON DELETE CASCADE
);

-- Clerk
CREATE TABLE Clerk (
    Employee_ID VARCHAR(10) PRIMARY KEY,
    Admin_Role VARCHAR(50),
    FOREIGN KEY (Employee_ID) REFERENCES Employee(Employee_ID) ON DELETE CASCADE
);


-- =============================================
-- RELATIONSHIP TABLES (from Business Rules)
-- =============================================

-- 1. Dispatcher assigns Routes to Trucks (M:N relationship)
CREATE TABLE Route_Assignment (
    Assignment_ID INT AUTO_INCREMENT PRIMARY KEY,
    Dispatcher_ID VARCHAR(10) NOT NULL,
    Truck_ID VARCHAR(20) NOT NULL,
    Route_ID VARCHAR(10) NOT NULL,
    Assignment_Date DATE NOT NULL,
    FOREIGN KEY (Dispatcher_ID) REFERENCES Dispatcher(Employee_ID),
    FOREIGN KEY (Truck_ID) REFERENCES Truck(Truck_ID),
    FOREIGN KEY (Route_ID) REFERENCES Route(Route_ID)
);

-- 2. Dispatcher Dispatches First Responder to Emergency
CREATE TABLE Dispatch (
    Dispatch_ID INT AUTO_INCREMENT PRIMARY KEY,
    Dispatcher_ID VARCHAR(10) NOT NULL,
    FirstResponder_ID VARCHAR(10) NOT NULL,
    Emergency_ID INT NOT NULL,
    Dispatch_Time DATETIME NOT NULL,
    FOREIGN KEY (Dispatcher_ID) REFERENCES Dispatcher(Employee_ID),
    FOREIGN KEY (FirstResponder_ID) REFERENCES First_Responder(Employee_ID),
    FOREIGN KEY (Emergency_ID) REFERENCES Emergency(Emergency_ID)
);

-- 3. Mechanic maintains Trucks (M:N relationship)
CREATE TABLE Maintenance (
    Maintenance_ID INT AUTO_INCREMENT PRIMARY KEY,
    Mechanic_ID VARCHAR(10) NOT NULL,
    Truck_ID VARCHAR(20) NOT NULL,
    Maintenance_Date DATE NOT NULL,
    Work_Performed TEXT,
    FOREIGN KEY (Mechanic_ID) REFERENCES Mechanic(Employee_ID),
    FOREIGN KEY (Truck_ID) REFERENCES Truck(Truck_ID)
);

-- 4. Clerk logs Maintenance query with Mechanic
CREATE TABLE Maintenance_Query (
    Query_ID INT AUTO_INCREMENT PRIMARY KEY,
    Clerk_ID VARCHAR(10) NOT NULL,
    Mechanic_ID VARCHAR(10) NOT NULL,
    Truck_ID VARCHAR(20) NOT NULL,
    Query_Date DATE NOT NULL,
    Description TEXT NOT NULL,
    Status VARCHAR(20) DEFAULT 'Open',
    FOREIGN KEY (Clerk_ID) REFERENCES Clerk(Employee_ID),
    FOREIGN KEY (Mechanic_ID) REFERENCES Mechanic(Employee_ID),
    FOREIGN KEY (Truck_ID) REFERENCES Truck(Truck_ID)
);

-- 5. Clerk assigns Dispatcher shifts (M:N relationship)
CREATE TABLE Shift_Assignment (
    Shift_ID INT AUTO_INCREMENT PRIMARY KEY,
    Clerk_ID VARCHAR(10) NOT NULL,
    Dispatcher_ID VARCHAR(10) NOT NULL,
    Shift_Date DATE NOT NULL,
    Shift_Type VARCHAR(20) NOT NULL,  -- Morning, Afternoon, Night
    FOREIGN KEY (Clerk_ID) REFERENCES Clerk(Employee_ID),
    FOREIGN KEY (Dispatcher_ID) REFERENCES Dispatcher(Employee_ID)
);


