-- =============================================
-- QUERY TO RECREATE ORIGINAL REPORT (Question 2.2)
-- =============================================

SELECT 
    d.Employee_ID AS Driver_ID,
    e.First_Name AS Driver_Name,
    e.Last_Name AS Driver_Surname,
    d.Licence_Type,
    d.Driver_Desc,
    d.Truck_ID,
    t.Truck_Desc,
    d.Route_ID AS Route
FROM Driver d
JOIN Employee e ON d.Employee_ID = e.Employee_ID
JOIN Truck t ON d.Truck_ID = t.Truck_ID
ORDER BY d.Employee_ID;
