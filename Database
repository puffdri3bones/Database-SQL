DROP DATABASE IF EXISTS rgi_Trucking;
CREATE DATABASE IF NOT EXISTS rgi_Trucking;
USE rgi_Trucking;

CREATE TABLE License (
    License_Type VARCHAR(10) PRIMARY KEY, 
    Description VARCHAR(100)
);

CREATE TABLE Truck (
    Truck_ID INT PRIMARY KEY,
    Truck_Desc VARCHAR(100)
);

CREATE TABLE Route (
    Route_ID VARCHAR(20) PRIMARY KEY
);

CREATE TABLE Employee (
    D VARCHAR(20) PRIMARY KEY,
    Name VARCHAR(50),
    Surname VARCHAR(50)
);

CREATE TABLE Driver (
    D VARCHAR(20) PRIMARY KEY,
    License_Type VARCHAR(10),
    FOREIGN KEY (D) REFERENCES Employee(D),
    FOREIGN KEY (License_Type) REFERENCES License(License_Type)
);

CREATE TABLE Dispatcher (
    D VARCHAR(20) PRIMARY KEY,
    FOREIGN KEY (D) REFERENCES Employee(D)
);

CREATE TABLE Mechanic(
    D VARCHAR(20) PRIMARY KEY,
    FOREIGN KEY (D) REFERENCES Employee(D)
);

CREATE TABLE Clerk(
    D VARCHAR(20) PRIMARY KEY,
    FOREIGN KEY (D) REFERENCES Employee(D)
);

CREATE TABLE Assignment (
    Assignment_ID INT AUTO_INCREMENT PRIMARY KEY,
    Driver_ID VARCHAR(20),
    Truck_ID INT,
    Route_ID VARCHAR(20),
    Dispatcher_ID VARCHAR(20),
    FOREIGN KEY (Driver_ID) REFERENCES Driver(D), 
    FOREIGN KEY (Truck_ID) REFERENCES Truck(Truck_ID),
    FOREIGN KEY (Route_ID) REFERENCES Route(Route_ID),
    FOREIGN KEY (Dispatcher_ID) REFERENCES Dispatcher(D)
);

CREATE TABLE Maintenence_Request (
    Request_ID INT AUTO_INCREMENT PRIMARY KEY,
    Truck_ID INT,
    Clerk_ID VARCHAR(20),
    Mechanic_ID VARCHAR(20),
    Description VARCHAR(100),
    FOREIGN KEY (Truck_ID) REFERENCES Truck(Truck_ID),
    FOREIGN KEY (Clerk_ID) REFERENCES Clerk(D),
    FOREIGN KEY (Mechanic_ID) REFERENCES Mechanic(D)

);

